rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Email-verified accounts only — blocks throwaway accounts from spamming
    // storage with garbage uploads.
    function isVerified() {
      return isAuth() && request.auth.token.email_verified == true;
    }

    // Allow only common image MIME types (no SVG — XSS via uploaded SVG is
    // a known attack vector when files are served back at the browser).
    function isAllowedImage() {
      return request.resource != null
             && request.resource.contentType in [
                  'image/jpeg', 'image/png', 'image/webp',
                  'image/gif', 'image/heic', 'image/heif'
                ];
    }

    function underSize(maxBytes) {
      return request.resource != null
             && request.resource.size > 0
             && request.resource.size < maxBytes;
    }

    // ─── User avatars ───────────────────────────────────────────────────────
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid)
                   && isVerified()
                   && isAllowedImage()
                   && underSize(5 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    // ─── Cover photos ───────────────────────────────────────────────────────
    match /covers/{uid}/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid)
                   && isVerified()
                   && isAllowedImage()
                   && underSize(8 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    // ─── Post images ────────────────────────────────────────────────────────
    match /posts/{uid}/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid)
                   && isVerified()
                   && isAllowedImage()
                   && underSize(10 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    // ─── Plant photos ───────────────────────────────────────────────────────
    match /plants/{uid}/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid)
                   && isVerified()
                   && isAllowedImage()
                   && underSize(10 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    // ─── Product images — scoped to the vendor's UID directory ──────────────
    match /products/{uid}/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid)
                   && isVerified()
                   && isAllowedImage()
                   && underSize(10 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    // ─── Story images ───────────────────────────────────────────────────────
    match /stories/{uid}/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid)
                   && isVerified()
                   && isAllowedImage()
                   && underSize(10 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    // ─── Return request images — buyer-private ──────────────────────────────
    match /returns/{uid}/{fileName} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
                   && isVerified()
                   && isAllowedImage()
                   && underSize(10 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    // ─── Ad creative images ─────────────────────────────────────────────────
    match /ads/{uid}/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid)
                   && isVerified()
                   && isAllowedImage()
                   && underSize(8 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    // ─── Group cover images — only the group creator may write ──────────────
    match /groups/{groupId}/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && isVerified()
                   && isAllowedImage()
                   && underSize(10 * 1024 * 1024)
                   && firestore.get(/databases/(default)/documents/groups/$(groupId)).data.creatorId
                        == request.auth.uid;
      allow delete: if isAuth()
                    && firestore.get(/databases/(default)/documents/groups/$(groupId)).data.creatorId
                         == request.auth.uid;
    }

    // ─── Default deny ───────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
