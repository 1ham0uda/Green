rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuth() && userDoc().role == 'admin';
    }

    function isBusiness() {
      return isAuth() && (userDoc().role == 'business' || userDoc().role == 'admin');
    }

    function notBanned() {
      return isAuth() && userDoc().isBanned != true;
    }

    // ─── Handle registry ────────────────────────────────────────────────────
    // Written atomically during signup via transaction. No updates — handles are permanent.
    match /handles/{handle} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      // Owners may only update profile-level fields; privileged fields (role,
      // isBanned, isVerified, etc.) are admin-only to prevent self-escalation.
      allow update: if isAdmin()
                    || (isOwner(uid)
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(['displayName', 'bio', 'photoURL',
                                       'coverPhotoURL', 'handle',
                                       'country', 'governorate', 'city',
                                       'updatedAt']));
      allow delete: if isAdmin();
    }

    // ─── Posts ──────────────────────────────────────────────────────────────
    match /posts/{postId} {
      // Approved posts are public; pending/rejected only visible to the author or admin
      allow read: if resource.data.status == "approved"
                  || (isAuth() && resource.data.authorId == request.auth.uid)
                  || isAdmin();
      allow create: if isAuth() && notBanned();
      allow update: if (isAuth() && resource.data.authorId == request.auth.uid)
                    || isAdmin();
      allow delete: if (isAuth() && resource.data.authorId == request.auth.uid)
                    || isAdmin();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId) && notBanned();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth() && notBanned();
        allow update: if isAuth() && resource.data.authorId == request.auth.uid;
        allow delete: if (isAuth() && resource.data.authorId == request.auth.uid)
                      || isAdmin();
      }
    }

    // ─── Follows ────────────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuth()
                    && notBanned()
                    && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth()
                    && resource.data.followerId == request.auth.uid;
    }

    // ─── Plants ─────────────────────────────────────────────────────────────
    match /plants/{plantId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if (isAuth() && resource.data.ownerId == request.auth.uid)
                    || isAdmin();
      allow delete: if (isAuth() && resource.data.ownerId == request.auth.uid)
                    || isAdmin();
    }

    // ─── Competitions ────────────────────────────────────────────────────────
    match /competitions/{competitionId} {
      allow read: if true;
      allow write: if isAdmin();

      match /entries/{entryId} {
        allow read: if true;
        allow create: if isAuth() && notBanned()
                      && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();

        match /votes/{userId} {
          allow read: if true;
          allow write: if isOwner(userId) && notBanned();
        }
      }
    }

    // ─── Products ────────────────────────────────────────────────────────────
    match /products/{productId} {
      // Approved products are public; pending/rejected only visible to the vendor or admin
      allow read: if resource.data.status == "approved"
                  || (isAuth() && resource.data.vendorId == request.auth.uid)
                  || isAdmin();
      allow create: if isBusiness()
                    && notBanned()
                    && request.resource.data.vendorId == request.auth.uid;
      allow update: if (isBusiness() && resource.data.vendorId == request.auth.uid)
                    || isAdmin();
      allow delete: if (isBusiness() && resource.data.vendorId == request.auth.uid)
                    || isAdmin();
    }

    // ─── Orders ─────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuth()
                  && (resource.data.buyerId == request.auth.uid
                      || resource.data.vendorId == request.auth.uid
                      || isAdmin());
      allow create: if isAuth() && notBanned()
                    && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAdmin()
                    || (isBusiness() && resource.data.vendorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── Return Requests ────────────────────────────────────────────────────
    match /returnRequests/{requestId} {
      allow read: if isAuth()
                  && (resource.data.buyerId == request.auth.uid
                      || resource.data.vendorId == request.auth.uid
                      || isAdmin());
      allow create: if isAuth() && notBanned()
                    && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Carts ──────────────────────────────────────────────────────────────
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── Notifications ───────────────────────────────────────────────────────
    match /users/{userId}/notifications/{notifId} {
      allow read: if isOwner(userId);
      allow create: if isAuth();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─── Reports ────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && notBanned();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Verification Requests ───────────────────────────────────────────────
    match /verificationRequests/{requestId} {
      allow read: if isAuth()
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth()
                    && notBanned()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Moderation Logs ─────────────────────────────────────────────────────
    match /moderationLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ─── System Logs ────────────────────────────────────────────────────────
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ─── Groups ──────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
                    && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuth()
                    && (resource.data.creatorId == request.auth.uid || isAdmin());
      allow delete: if isAuth()
                    && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /groupMembers/{memberId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /groupPosts/{postId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
                    && request.resource.data.authorId == request.auth.uid
                    && exists(/databases/$(database)/documents/groupMembers/$(request.resource.data.groupId + "_" + request.auth.uid));
      allow delete: if isAuth()
                    && (resource.data.authorId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    // ─── Stories ─────────────────────────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ─── Announcements ───────────────────────────────────────────────────────
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Ads ─────────────────────────────────────────────────────────────────
    match /ads/{adId} {
      // Approved ads are public; others only visible to the owner or admin
      allow read: if resource.data.status == "approved"
                  || (isAuth() && resource.data.vendorId == request.auth.uid)
                  || isAdmin();
      allow create: if isBusiness()
                    && notBanned()
                    && request.resource.data.vendorId == request.auth.uid;
      allow update: if isAdmin()
                    || (isAuth() && resource.data.vendorId == request.auth.uid
                        && resource.data.status == "pending");
      allow delete: if isAdmin();
    }

    match /adImpressions/{impId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // ─── Highlights ──────────────────────────────────────────────────────────
    match /highlights/{highlightId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ─── Saved Posts ─────────────────────────────────────────────────────────
    match /savedPosts/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ─── Muted Users ─────────────────────────────────────────────────────────
    match /mutedUsers/{docId} {
      allow read: if isAuth() && resource.data.muterId == request.auth.uid;
      allow create: if isAuth()
                    && request.resource.data.muterId == request.auth.uid;
      allow delete: if isAuth() && resource.data.muterId == request.auth.uid;
      allow update: if false;
    }
  }
}
